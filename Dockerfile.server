FROM maven:3.9.9-eclipse-temurin-17 AS build
WORKDIR /workspace

COPY pom.xml testng.xml ./
COPY src ./src

RUN mvn -q -DskipTests package

FROM eclipse-temurin:17-jre
WORKDIR /app

COPY --from=build /workspace/target/rest-api-framework-1.0.0-shaded.jar /app/app.jar

EXPOSE 9876
ENV SERVER_PORT=9876

ENTRYPOINT ["sh", "-c", "java -Dserver.port=${SERVER_PORT} -jar /app/app.jar"]

