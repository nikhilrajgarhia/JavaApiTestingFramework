{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accessToken",
    "refreshToken",
    "tokenType",
    "accessTokenExpiresAt",
    "refreshTokenExpiresAt"
  ],
  "properties": {
    "accessToken": {
      "type": "string"
    },
    "refreshToken": {
      "type": "string"
    },
    "tokenType": {
      "type": "string"
    },
    "accessTokenExpiresAt": {
      "type": "string"
    },
    "refreshTokenExpiresAt": {
      "type": "string"
    }
  }
}

