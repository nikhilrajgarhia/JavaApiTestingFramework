  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "email",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    }
  }
}

